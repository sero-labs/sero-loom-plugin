{
  "name": "@sero-ai/plugin-loom",
  "version": "0.2.1",
  "description": "Loom — generative art studio for Sero. The agent authors real GLSL shaders, looks at its own output, and refines. Wallpaper capture included.",
  "keywords": [
    "pi-package",
    "sero-plugin"
  ],
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sero-labs/sero-loom-plugin.git"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "test": "vitest run --root .",
    "test:watch": "vitest --root .",
    "typecheck": "tsc --noEmit -p ui/tsconfig.json && tsc --noEmit -p extension/tsconfig.json"
  },
  "pi": {
    "extensions": [
      "./extension/index.ts"
    ],
    "prompts": [
      "./prompts/loom.md"
    ]
  },
  "sero": {
    "app": {
      "id": "loom",
      "styleIsolation": "scope",
      "name": "Loom",
      "icon": "palette",
      "scope": "global",
      "stateFile": ".sero/apps/loom/state.json",
      "ui": "./dist/ui/remoteEntry.js",
      "component": "LoomApp",
      "devPort": 5199
    },
    "plugin": {
      "category": "creative",
      "tags": [
        "generative",
        "art",
        "shaders",
        "glsl",
        "agent",
        "wallpaper"
      ],
      "minSeroVersion": "0.1.0",
      "requiredHostCapabilities": [
        "appAgent.invokeTool"
      ],
      "bridgeTools": false,
      "preBuilt": false
    }
  },
  "dependencies": {
    "typebox": "^1.1.38"
  },
  "peerDependencies": {
    "@earendil-works/pi-agent-core": ">=0.80.6",
    "@earendil-works/pi-ai": ">=0.80.6",
    "@earendil-works/pi-coding-agent": ">=0.80.6",
    "@earendil-works/pi-tui": ">=0.80.6"
  },
  "devDependencies": {
    "@sero-ai/plugin-vite": "^0.1.0",
    "@module-federation/vite": "1.11.0",
    "@sero-ai/app-runtime": "^0.1.3",
    "@sero-ai/ui": "^0.3.2",
    "@tailwindcss/vite": "^4.1.18",
    "@types/node": "^22.19.11",
    "@types/react": "^19.2.13",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.7.0",
    "lucide-react": "^0.563.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "shadcn": "^3.8.5",
    "tailwindcss": "^4.1.18",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.3",
    "vite": "^6.4.2",
    "vitest": "^4.1.7"
  }
}
